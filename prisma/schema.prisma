generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  pending
  payment_pending
  paid
  processing
  packed
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentMethod {
  razorpay
  cod
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum StockStatus {
  in_stock
  low_stock
  out_of_stock
}

enum EmailJobType {
  contact_customer
  contact_admin
  manuscript_customer
  manuscript_admin
  newsletter_customer
  newsletter_admin
  cod_order_customer
  cod_order_admin
  paid_order_customer
  paid_order_admin
  verification_email
  welcome_email
  order_shipped
  order_delivered
  order_refunded
  low_stock_admin
  failed_payment_admin
}

enum EmailJobStatus {
  queued
  processing
  completed
  failed
}

enum UserRole {
  ADMIN
  CUSTOMER
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  fullName        String?
  phone           String?
  role            UserRole @default(CUSTOMER)
  isActive        Boolean  @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
  wishlist        WishlistItem[]
  reviews         Review[]
  addresses       Address[]
  cartItems       CartItem[]

  @@index([role])
  @@map("AdminUser")
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  label        String   @default("Home")
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String   @default("India")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model SiteSettings {
  id               String   @id
  heroTagline      String?
  heroTaglineEn    String?
  missionStatement String?
  featuredAuthorId String?
  facebookUrl      String?
  instagramUrl     String?
  youtubeUrl       String?
  linkedinUrl      String?
  editorialEmail   String?
  submissionsEmail String?
  rightsEmail      String?
  supportPhone     String?
  whatsappPhone    String?
  postalAddress    String?
  featuredAuthor   Author?  @relation("FeaturedAuthor", fields: [featuredAuthorId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Author {
  id                 String        @id @default(cuid())
  name               String
  slug               String        @unique
  bio                String?
  photoUrl           String?
  featured           Boolean       @default(false)
  awards             AuthorAward[]
  books              Book[]
  posts              BlogPost[]
  featuredInSettings SiteSettings[] @relation("FeaturedAuthor")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model AuthorAward {
  id        String   @id @default(cuid())
  authorId  String
  label     String
  position  Int      @default(0)
  author    Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([authorId, position])
}

model Genre {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  books       BookGenre[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Book {
  id              String      @id @default(cuid())
  title           String
  titleEn         String?
  slug            String      @unique
  authorId        String?
  coverImageUrl   String?
  synopsis        String?
  pullQuote       String?
  price           Float?
  compareAtPrice  Float?
  stockQuantity   Int         @default(12)
  lowStockThreshold Int       @default(3)
  stockStatus     StockStatus @default(in_stock)
  buyLink         String?
  publicationDate String?
  pageCount       Int?
  isbn            String?
  language        String?
  featured        Boolean     @default(false)
  chapterPreview  String?
  averageRating   Float?
  reviewCount     Int         @default(0)
  publisher       String?
  galleryImages   String[]
  tableOfContents String?
  soldCount       Int         @default(0)
  viewCount       Int         @default(0)
  searchVector    String?     @default("")
  coverBlurDataUrl String?
  author          Author?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  genres          BookGenre[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([stockStatus, stockQuantity])
  @@index([soldCount])
  @@index([viewCount])
}

model BookGenre {
  id        String   @id @default(cuid())
  bookId    String
  genreId   String
  position  Int      @default(0)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  genre     Genre    @relation(fields: [genreId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([bookId, genreId])
  @@index([bookId, position])
  @@index([genreId])
}

model BlogPost {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  category     String?
  coverImageUrl String?
  excerpt      String?
  body         String?
  publishedAt  String?
  featured     Boolean  @default(false)
  authorId     String?
  author       Author?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id         String   @id @default(cuid())
  fullName   String
  email      String
  department String
  message    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ManuscriptSubmission {
  id              String   @id @default(cuid())
  fullName        String
  email           String
  phone           String
  city            String
  manuscriptTitle String
  genre           String
  wordCount       Int
  language        String
  synopsis        String
  status          String   @default("new")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model NewsletterSubscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Order {
  id                 String        @id @default(cuid())
  userId             String?
  couponId           String?
  status             OrderStatus   @default(pending)
  paymentMethod      PaymentMethod @default(razorpay)
  paymentStatus      PaymentStatus @default(pending)
  customerName       String
  customerEmail      String
  customerPhone      String
  addressLine1       String
  addressLine2       String?
  city               String
  state              String
  postalCode         String
  country            String
  subtotalAmount     Float
  shippingAmount     Float         @default(0)
  shippingMethod     String        @default("standard")
  discountAmount     Float         @default(0)
  couponCode         String?
  totalAmount        Float
  invoiceNumber      String?       @unique
  invoiceIssuedAt    DateTime?
  trackingNumber     String?
  carrier            String?
  razorpayOrderId    String?       @unique
  razorpayPaymentId  String?       @unique
  paidAt             DateTime?
  paymentCollectedAt DateTime?
  inventoryCommittedAt DateTime?
  inventoryReleasedAt DateTime?
  processingAt       DateTime?
  packedAt           DateTime?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  refundedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  coupon             Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items              OrderItem[]

  @@index([userId])
  @@index([couponId])
  @@index([customerEmail])
  @@index([status, paymentStatus])
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  bookId       String
  bookSlug     String
  bookTitle    String
  bookAuthor   String
  bookCoverUrl String?
  quantity     Int
  price        Float
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model EmailJob {
  id          String         @id @default(cuid())
  type        EmailJobType
  status      EmailJobStatus @default(queued)
  dedupeKey   String?        @unique
  payload     Json
  attempts    Int            @default(0)
  maxAttempts Int            @default(5)
  runAt       DateTime       @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  lastError   String?
  completedAt DateTime?
  failedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, runAt])
  @@index([type, status])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model WishlistItem {
  id           String   @id @default(cuid())
  userId       String
  bookId       String
  bookSlug     String
  bookTitle    String
  bookAuthor   String
  bookCoverUrl String?
  price        Float?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([userId, bookId])
  @@index([userId])
}

model Review {
  id               String   @id @default(cuid())
  bookId           String
  bookSlug         String
  userId           String
  reviewerName     String
  rating           Int
  title            String?
  body             String?
  approved         Boolean  @default(false)
  purchaseVerified Boolean  @default(false)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, bookId])
  @@index([bookId, approved])
  @@index([userId])
}

model Coupon {
  id           String      @id @default(cuid())
  code         String      @unique
  type         CouponType
  value        Float
  minOrderAmount Float?
  maxUses      Int?
  usedCount    Int         @default(0)
  expiresAt    DateTime?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  uses         CouponUse[]
  orders        Order[]

  @@index([code, isActive])
}

model CouponUse {
  id        String   @id @default(cuid())
  couponId  String
  orderId   String   @unique
  userId    String?
  discount  Float
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  createdAt DateTime @default(now())

  @@index([couponId])
  @@index([userId])
}

enum CouponType {
  percent
  flat
}

model SearchQuery {
  id        String   @id @default(cuid())
  query     String   @unique
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([count])
}

model OrderIdempotency {
  id        String   @id @default(cuid())
  key       String   @unique
  orderId   String?
  createdAt DateTime @default(now())
  expiresAt DateTime
}
